## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio 2015 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Database files
*.db
*.db-shm
*.db-wal
ImageManagement.db

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Node modules
node_modules/

# Uploaded images (optional - comment out if you want to include sample images)
wwwroot/images/*
!wwwroot/images/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
