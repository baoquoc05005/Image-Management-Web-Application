@model IEnumerable<ImageUploadMVC>

@{
    ViewData["Title"] = "All Images";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-grid-3x3-gap"></i> Image Gallery</h2>
            <a asp-action="Upload" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Upload New
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle"></i> No images uploaded yet. 
                <a asp-action="Upload" class="alert-link">Upload your first image</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100">
                            <a asp-action="Display" asp-route-id="@item.Id">
                                <img src="~/images/@item.ImageFileName" class="card-img-top image-thumbnail" alt="@item.Name" />
                            </a>
                            <div class="card-body">
                                <h5 class="card-title">
                                    <a asp-action="Display" asp-route-id="@item.Id" class="text-decoration-none">
                                        @item.Name
                                    </a>
                                </h5>
                                <p class="card-text">
                                    <strong>Age:</strong> @item.Age years<br />
                                    <strong>DOB:</strong> @item.Dob.ToString("MM/dd/yyyy")<br />
                                    <strong>File:</strong> <small class="text-muted">@item.ImageFileName</small>
                                </p>
                            </div>
                            <div class="card-footer bg-transparent">
                                <div class="d-grid gap-2">
                                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
