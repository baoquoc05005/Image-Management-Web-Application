@model ImageUploadMVC

@{
    ViewData["Title"] = "Display Image";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-image"></i> Image Details</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <img src="~/images/@Model.ImageFileName" alt="@Model.Name" class="image-display mb-3" />
                    </div>
                    <div class="col-md-6">
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th width="40%">ID</th>
                                    <td>@Model.Id</td>
                                </tr>
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.Name</td>
                                </tr>
                                <tr>
                                    <th>Age</th>
                                    <td>@Model.Age years</td>
                                </tr>
                                <tr>
                                    <th>Date of Birth</th>
                                    <td>@Model.Dob.ToString("MMMM dd, yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Image File Name</th>
                                    <td>@Model.ImageFileName</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-3">
                    <a asp-action="List" class="btn btn-primary">
                        <i class="bi bi-list"></i> View All Images
                    </a>
                    <a asp-action="Upload" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Upload Another Image
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete This Image
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
