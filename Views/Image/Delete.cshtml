@model ImageUploadMVC

@{
    ViewData["Title"] = "Delete Image";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-circle"></i> 
                    <strong>Warning!</strong> Are you sure you want to delete this image? This action cannot be undone.
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <img src="~/images/@Model.ImageFileName" alt="@Model.Name" class="image-display mb-3" />
                    </div>
                    <div class="col-md-6">
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th width="40%">ID</th>
                                    <td>@Model.Id</td>
                                </tr>
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.Name</td>
                                </tr>
                                <tr>
                                    <th>Age</th>
                                    <td>@Model.Age years</td>
                                </tr>
                                <tr>
                                    <th>Date of Birth</th>
                                    <td>@Model.Dob.ToString("MMMM dd, yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Image File Name</th>
                                    <td>@Model.ImageFileName</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-trash"></i> Yes, Delete Image
                        </button>
                        <a asp-action="List" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
